{
  "name": "bonae",
  "private": true,
  "version": "1.0.0",
  "description": "BONAE TECH static marketing site with git-backed content admin",
  "scripts": {
    "content:build": "npm ci --prefix packages/content && npm --prefix packages/content run build",
    "content:validate": "npm --prefix packages/content run validate:published",
    "dev": "npm --prefix apps/static run dev",
    "build": "npm --prefix apps/static run build",
    "preview": "npm --prefix apps/static run preview",
    "admin:dev": "npm --prefix apps/admin run dev",
    "admin:dev:mock": "npm run content:build && npm --prefix apps/admin run dev:mock",
    "admin:build": "npm --prefix apps/admin run build",
    "worker:build": "npm --prefix workers/content-api run build",
    "worker:dev": "npm --prefix workers/content-api run dev",
    "worker:test": "npm --prefix workers/content-api run test",
    "build:all": "make build-all",
    "deploy:site": "make deploy-site",
    "deploy:admin": "make deploy-admin",
    "deploy:worker": "make deploy-worker",
    "deploy:all": "make deploy-all"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  }
}
