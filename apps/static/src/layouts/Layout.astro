---
import '../styles/global.css';
import type { Translations, SiteSettings } from '@bonae/content';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  t: Translations;
  settings: SiteSettings;
  whatsappHref: string;
}

const { t, whatsappHref, settings } = Astro.props;
const isEn = t.lang === 'en';
const canonicalES = Astro.site ? new URL('/', Astro.site).href : '/';
const canonicalEN = Astro.site ? new URL('/en/', Astro.site).href : '/en/';
---

<!doctype html>
<html lang={t.lang} class="scroll-smooth" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="google" content="notranslate" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.metaDescription} />
    <meta name="theme-color" content="#40575D" />

    <link rel="alternate" hreflang="es" href={canonicalES} />
    <link rel="alternate" hreflang="en" href={canonicalEN} />
    <link rel="alternate" hreflang="x-default" href={canonicalES} />

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${t.siteName} — ${t.siteTagline}`} />
    <meta property="og:description" content={t.metaDescription} />
    <meta property="og:locale" content={isEn ? 'en_US' : 'es_VE'} />

    <title>{t.siteName} — {t.siteTagline}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
    <WhatsAppFloat href={whatsappHref} />
    <CookieBanner t={t} settings={settings} />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
  </body>
</html>
