---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ValueProp from '../components/ValueProp.astro';
import About from '../components/About.astro';
import Templates from '../components/Templates.astro';
import Plans from '../components/Plans.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { publishedEs, siteSettings, whatsappHrefFor } from '../lib/content';

const t = publishedEs;
const whatsappHref = whatsappHrefFor(t);
---

<Layout t={t} settings={siteSettings} whatsappHref={whatsappHref}>
  <Header t={t} />
  <main>
    <Hero t={t} whatsappHref={whatsappHref} />
    <ValueProp t={t} />
    <Plans t={t} whatsappHref={whatsappHref} />
    <Templates t={t} />
    <About t={t} />
    <Contact t={t} whatsappHref={whatsappHref} settings={siteSettings} />
  </main>
  <Footer t={t} settings={siteSettings} whatsappHref={whatsappHref} />
</Layout>
