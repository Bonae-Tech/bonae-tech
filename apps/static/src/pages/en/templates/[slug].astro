---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import TemplateDetail from '../../../components/TemplateDetail.astro';
import {
  publishedEn,
  siteSettings,
  whatsappHrefFor,
  whatsappHrefForTemplate,
} from '../../../lib/content';
import { findTemplateBySlug, liveTemplates } from '../../../lib/templates';

export function getStaticPaths() {
  return liveTemplates(publishedEn).map((item) => ({
    params: { slug: item.slug },
  }));
}

const { slug } = Astro.params;
const t = publishedEn;
const item = findTemplateBySlug(t, slug ?? '');

if (!item) {
  return Astro.redirect('/en/#plantillas');
}

const whatsappHref = whatsappHrefFor(t);
const templateWhatsappHref = whatsappHrefForTemplate(t, item.title);
const pageTitle = `${item.title} — ${t.siteName}`;
const pageDescription = item.detailDescription || item.description;
---

<Layout
  t={t}
  settings={siteSettings}
  whatsappHref={whatsappHref}
  pageTitle={pageTitle}
  pageDescription={pageDescription}
>
  <Header t={t} />
  <main class="flex-1 flex flex-col">
    <TemplateDetail t={t} item={item} whatsappHref={templateWhatsappHref} />
  </main>
  <Footer t={t} settings={siteSettings} whatsappHref={whatsappHref} />
</Layout>
