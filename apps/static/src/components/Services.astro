---
import type { Translations } from '@bonae/content';
import ServiceCard from './ServiceCard.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const columnClasses = {
  1: 'md:grid-cols-1',
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
} as const;
---

<section id="servicios-completos" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-cream text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.services.sectionBadge}
      </span>
      <h2 class="section-title">{t.services.title}</h2>
      <p class="section-subtitle">{t.services.subtitle}</p>
    </div>

    <div class="space-y-16">
      {t.services.categories.map((category) => (
        <div>
          <h3 class="text-xl font-bold text-dark-blue mb-6">{category.title}</h3>
          <div class={`grid gap-6 ${columnClasses[category.columns]}`}>
            {category.items.map((item) => (
              <ServiceCard icon={item.icon} title={item.title} description={item.description} />
            ))}
          </div>
        </div>
      ))}

      <p class="text-center text-pacificblue text-sm italic max-w-2xl mx-auto">
        {t.services.expansion}
      </p>
    </div>
  </div>
</section>
