---
import type { Translations, SiteSettings } from '@bonae/content';

interface Props {
  t: Translations;
  whatsappHref: string;
  settings: SiteSettings;
}

const { t, whatsappHref, settings } = Astro.props;

const instagramUrl = settings.socialLinks.instagram.trim() || '#';
const linkedinUrl = settings.socialLinks.linkedin.trim() || '#';

const emailTitle = t.lang === 'es' ? 'Correo electrónico' : 'Email';
const socialTitle = t.lang === 'es' ? 'Redes sociales' : 'Social media';
---

<section id="contacto" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-cream text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.contact.sectionBadge}
      </span>
      <h2 class="section-title">{t.contact.title}</h2>
      <p class="section-subtitle mb-10">{t.contact.subtitle}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <div class="card">
        <form action="/api/contact" method="POST" class="space-y-4" id="contact-form">
          <input type="hidden" name="form-name" value="contact" />
          <div>
            <label for="name" class="block text-sm font-medium text-body mb-1">
              {t.contact.form.name} *
            </label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-2 rounded-lg border border-light-blue/30 focus:border-dark-blue focus:ring-1 focus:ring-dark-blue outline-none transition-colors" autocomplete="name" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-body mb-1">
              {t.contact.form.email} *
            </label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-2 rounded-lg border border-light-blue/30 focus:border-dark-blue focus:ring-1 focus:ring-dark-blue outline-none transition-colors" autocomplete="email" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-body mb-1">
              {t.contact.form.phone} *
            </label>
            <input type="tel" id="phone" name="phone" required class="w-full px-4 py-2 rounded-lg border border-light-blue/30 focus:border-dark-blue focus:ring-1 focus:ring-dark-blue outline-none transition-colors" autocomplete="tel" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-body mb-1">
              {t.contact.form.message} *
            </label>
            <textarea id="message" name="message" rows={4} required class="w-full px-4 py-2 rounded-lg border border-light-blue/30 focus:border-dark-blue focus:ring-1 focus:ring-dark-blue outline-none transition-colors resize-none"></textarea>
          </div>
          <button type="submit" class="btn-secondary w-full justify-center">
            {t.contact.form.submit}
          </button>
        </form>
      </div>

      <div class="space-y-6">
        <div class="card space-y-6">
          <div>
            <h3 class="font-display font-bold text-terracotta mb-3">{t.contact.whatsappText}</h3>
            <div class="flex flex-wrap items-center gap-3">
              <a href={whatsappHref} class="text-dark-blue font-semibold hover:text-terracotta transition-colors">
                {t.contact.phone}
              </a>
              <a
                href={whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-whatsapp text-sm py-2 px-4"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            </div>
          </div>

          <div>
            <h3 class="font-display font-bold text-terracotta mb-2">{emailTitle}</h3>
            <a href={`mailto:${t.contact.email}`} class="text-body hover:text-terracotta transition-colors">
              {t.contact.email}
            </a>
          </div>

          <div class="rounded-xl border border-terracotta/30 bg-terracotta/10 px-4 py-4">
            <h3 class="font-display font-bold text-terracotta mb-2">{t.contact.location}</h3>
            <p class="text-sm text-body leading-relaxed">{t.contact.locationNote}</p>
          </div>

          <div>
            <h3 class="font-display font-bold text-terracotta mb-3">{socialTitle}</h3>
            <div class="flex gap-3">
              <a
                href={instagramUrl}
                target={instagramUrl === '#' ? undefined : '_blank'}
                rel={instagramUrl === '#' ? undefined : 'noopener noreferrer'}
                class="w-10 h-10 rounded-lg bg-gradient-to-br from-cyan/80 to-mid-blue text-white flex items-center justify-center shadow-md hover:brightness-110 transition-all"
                aria-label="Instagram"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a
                href={linkedinUrl}
                target={linkedinUrl === '#' ? undefined : '_blank'}
                rel={linkedinUrl === '#' ? undefined : 'noopener noreferrer'}
                class="w-10 h-10 rounded-lg bg-gradient-to-br from-cyan/80 to-mid-blue text-white flex items-center justify-center shadow-md hover:brightness-110 transition-all"
                aria-label="LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
