---
import type { Translations, SiteSettings } from '@bonae/content';

interface Props {
  t: Translations;
  settings: SiteSettings;
}

const { t, settings } = Astro.props;
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 bg-dark-blue-dark text-white px-4 py-4 shadow-lg border-t border-white/10"
  role="dialog"
  aria-live="polite"
  aria-label={t.cookieBanner.ariaLabel}
>
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-light-blue flex-1">
      {t.cookieBanner.message}{' '}
      <a href={settings.legalLinks.privacy || '#'} class="text-terracotta hover:text-terracotta-dark underline">{t.cookieBanner.privacy}</a>
    </p>
    <button
      type="button"
      id="cookie-accept"
      class="btn-secondary flex-shrink-0 py-2 px-4 text-sm"
    >
      {t.cookieBanner.accept}
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    const storageKey = 'bonae_cookies_accepted';
    const banner = document.getElementById('cookie-banner');
    const accept = document.getElementById('cookie-accept');
    if (!banner || !accept) return;

    if (typeof localStorage !== 'undefined' && localStorage.getItem(storageKey)) {
      banner.classList.add('hidden');
      return;
    }

    accept.addEventListener('click', () => {
      if (typeof localStorage !== 'undefined') localStorage.setItem(storageKey, 'true');
      banner.classList.add('hidden');
    });
  })();
</script>
