---
import type { Translations } from '@bonae/content';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const base = t.lang === 'en' ? '/en/' : '/';
---

<section class="relative text-white overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-dark-blue via-dark-blue-dark to-dark-blue" aria-hidden="true"></div>

  <video
    class="hero-bg-video absolute inset-0 w-full h-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    aria-hidden="true"
  >
    <source src="/videos/hero-tech.mp4" type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-gradient-to-br from-dark-blue/85 via-dark-blue-dark/80 to-dark-blue/75" aria-hidden="true"></div>

  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-terracotta via-terracotta to-terracotta"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28 lg:py-32">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-sm font-medium text-terracotta mb-6">
        <span class="w-2 h-2 rounded-full bg-terracotta animate-pulse"></span>
        {t.hero.badge}
      </div>

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        {t.hero.headline}
      </h1>

      <p class="text-lg sm:text-xl text-light-blue leading-relaxed mb-10 max-w-2xl">
        {t.hero.subheadline}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
        <a href={`${base}#servicios`} class="btn-secondary text-base">
          {t.hero.ctaSecondary}
        </a>
        <span class="text-sm text-light-blue flex items-center gap-1.5">
          <svg class="w-4 h-4 text-terracotta" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {t.hero.ctaSub}
        </span>
      </div>
    </div>

    <div class="hidden lg:flex absolute right-8 top-1/2 -translate-y-1/2 flex-col gap-4">
      <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-4 text-center min-w-[120px]">
        <div class="font-display text-3xl font-bold text-terracotta">30+</div>
        <div class="text-xs text-light-blue mt-1">{t.keyFigures.yearsLabel}</div>
      </div>
      <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-4 text-center">
        <div class="font-display text-3xl font-bold text-terracotta">{t.keyFigures.foundersCount}</div>
        <div class="text-xs text-light-blue mt-1">{t.keyFigures.foundersLabel}</div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    .hero-bg-video {
      display: none;
    }
  }
</style>
