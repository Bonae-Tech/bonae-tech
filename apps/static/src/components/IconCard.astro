---
import type { ValuePropIcon } from '@bonae/content';
import { valuePropIconMarkup } from '../lib/icons';

interface Props {
  icon: ValuePropIcon;
  title: string;
  description: string;
  backLabel: string;
  backDescription: string;
}

const { icon, title, description, backLabel, backDescription } = Astro.props;
---

<article class="flip-card group" tabindex="0">
  <div class="flip-card-inner">
    <div class="flip-card-front">
      <div class="w-20 h-20 rounded-2xl bg-cream text-dark-blue flex items-center justify-center mx-auto mb-5 shadow-md group-hover:bg-dark-blue group-hover:text-white transition-all duration-300 [&_svg]:w-8 [&_svg]:h-8">
        <Fragment set:html={valuePropIconMarkup[icon]} />
      </div>
      <h3 class="text-lg font-bold text-dark-blue mb-2">{title}</h3>
      {description !== title && (
        <p class="text-sm text-pacificblue leading-relaxed mb-5">{description}</p>
      )}
    </div>
    <div class="flip-card-back">
      <span class="flip-card-badge">{backLabel}</span>
      <p class="text-sm text-pacificblue leading-relaxed px-2">{backDescription}</p>
    </div>
  </div>
</article>
