---
import type { ValuePropIcon } from '@bonae/content';
import { valuePropIconSrc, valuePropIconAlt } from '../lib/icons';

interface Props {
  icon: ValuePropIcon;
  title: string;
  description: string;
  backLabel: string;
  backDescription: string;
}

const { icon, title, description, backLabel, backDescription } = Astro.props;
const src = valuePropIconSrc[icon];
const alt = valuePropIconAlt[icon] ?? title;
---

<article class="flip-card group" tabindex="0">
  <div class="flip-card-inner">
    <div class="flip-card-front">
      <div class="value-prop-icon-frame">
        <img
          src={src}
          alt={alt}
          width="768"
          height="768"
          loading="lazy"
          decoding="async"
          class="value-prop-icon-img"
        />
      </div>
      <h3 class="value-prop-card-title">{title}</h3>
      {description !== title && (
        <p class="value-prop-card-subtitle">{description}</p>
      )}
    </div>
    <div class="flip-card-back">
      <span class="flip-card-badge">{backLabel}</span>
      <p class="text-sm text-body leading-relaxed px-2">{backDescription}</p>
    </div>
  </div>
</article>
