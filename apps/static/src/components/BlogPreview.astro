---
import type { Translations } from '@bonae/content';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const base = t.lang === 'en' ? '/en/' : '/';
---

<section id="blog" class="py-20 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-white text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.nav.blog}
      </span>
      <h2 class="section-title">{t.blog.title}</h2>
      <p class="section-subtitle">{t.blog.subtitle}</p>
    </div>

    <div class="card max-w-2xl mx-auto text-center py-12 px-6">
      <p class="text-pacificblue mb-4">{t.blog.comingSoon}</p>
    </div>
  </div>
</section>
