---
import type { Translations } from '@bonae/content';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const avatarColors = [
  'from-dark-blue to-dark-blue-dark',
  'from-mid-blue to-dark-blue',
  'from-terracotta to-terracotta-dark',
];
---

<section id="nosotras" class="py-20 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-white text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.about.sectionBadge}
      </span>
      <h2 class="section-title">{t.about.title}</h2>
    </div>

    <h3 class="text-xl font-bold text-dark-blue text-center mb-10">
      {t.about.foundersTitle}
    </h3>
    <div class="grid md:grid-cols-3 gap-6">
      {t.about.members.map((member, i) => (
        <article class="card text-center group">
          <div class={`w-20 h-20 rounded-2xl bg-gradient-to-br ${avatarColors[i]} flex items-center justify-center mx-auto mb-5 shadow-md`}>
            <span class="text-2xl font-bold text-white">{member.initials}</span>
          </div>
          <div class="text-xs font-semibold text-terracotta uppercase tracking-wider mb-2">
            {member.role}
          </div>
          <p class="text-sm text-pacificblue leading-relaxed mb-5">{member.bio}</p>
          <div class="flex flex-col gap-2">
            {member.highlights.map((h) => (
              <div class="flex items-center justify-center gap-2 text-xs text-pacificblue">
                <span class="w-1.5 h-1.5 rounded-full bg-terracotta flex-shrink-0"></span>
                {h}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
