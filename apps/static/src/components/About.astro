---
import type { Translations } from '@bonae/content';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const avatarColors = [
  'from-mid-blue to-dark-blue-dark',
  'from-terracotta to-terracotta-dark',
  'from-cyan/80 to-mid-blue',
];

const particles = Array.from({ length: 24 }, (_, i) => {
  const col = (i % 12) / 11;
  const x = `${4 + col * 92}%`;
  const delay = `${-((i * 0.7) % 12).toFixed(1)}s`;
  const duration = `${10 + (i % 7)}s`;
  const size = `${(0.22 + (i % 5) * 0.06).toFixed(2)}rem`;
  const opacity = `${(0.45 + (i % 4) * 0.1).toFixed(2)}`;
  return { x, delay, duration, size, opacity };
});
---

<section id="nosotras" class="about-section" data-about-section>
  <div class="about-motion" aria-hidden="true">
    {particles.map((p) => (
      <span
        class="about-particle"
        style={`--x: ${p.x}; --delay: ${p.delay}; --duration: ${p.duration}; --size: ${p.size}; --opacity: ${p.opacity};`}
      />
    ))}
  </div>

  <div class="relative z-[1] max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-cream text-xs font-semibold uppercase tracking-wider mb-4 border border-white/20">
        {t.about.sectionBadge}
      </span>
      <h2 class="section-title text-cream">{t.about.title}</h2>
    </div>

    <h3 class="font-display text-xl font-bold text-cream/90 text-center mb-10">
      {t.about.foundersTitle}
    </h3>
    <div class="grid md:grid-cols-3 gap-6">
      {t.about.members.map((member, i) => (
        <article class="about-card card text-center group">
          <div class="about-avatar-wrap">
            <span class="about-ring about-ring--outer" aria-hidden="true"></span>
            <span class="about-ring about-ring--inner" aria-hidden="true"></span>
            <span class="about-ring-dot" aria-hidden="true"></span>
            <div class={`about-avatar w-20 h-20 rounded-2xl bg-gradient-to-br ${avatarColors[i]} flex items-center justify-center shadow-md`}>
              <span class="text-2xl font-bold text-white">{member.initials}</span>
            </div>
          </div>
          <h3 class="about-card-title font-display font-bold text-dark-blue tracking-tight mb-3">
            {member.role}
          </h3>
          <p class="text-sm text-body leading-relaxed mb-5">{member.bio}</p>
          <ul class="about-highlights flex flex-col gap-2.5">
            {member.highlights.map((h, hi) => (
              <li
                class="about-highlight flex items-center justify-center gap-2.5"
                style={`--hl-delay: ${0.2 + i * 0.22 + hi * 0.18}s`}
              >
                <span class="about-highlight-bullet" aria-hidden="true"></span>
                <span class="about-highlight-text">{h}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const section = document.querySelector('[data-about-section]');
  if (section) {
    const reveal = () => section.classList.add('is-inview');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            reveal();
            observer.disconnect();
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
      );
      observer.observe(section);
    } else {
      reveal();
    }
  }
</script>
