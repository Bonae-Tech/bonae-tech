---
import type { Translations } from '@bonae/content';
import { valuePropIconMarkup } from '../lib/icons';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="propuesta-valor" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-white text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.valueProp.sectionBadge}
      </span>
      <h2 class="section-title">{t.valueProp.title}</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.valueProp.items.map((item) => (
        <div class="card text-center group">
          <div class="w-12 h-12 rounded-xl bg-cream text-dark-blue flex items-center justify-center mx-auto mb-4 group-hover:bg-dark-blue group-hover:text-white transition-all duration-300">
            <Fragment set:html={valuePropIconMarkup[item.icon]} />
          </div>
          <h3 class="font-bold text-dark-blue mb-2">{item.title}</h3>
          <p class="text-pacificblue text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
