---
import type { Translations } from '@bonae/content';
import IconCard from './IconCard.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="servicios" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-white text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.valueProp.sectionBadge}
      </span>
      <h2 class="section-title">{t.valueProp.title}</h2>
      <p class="section-subtitle">{t.valueProp.subheadline}</p>
    </div>
    <div class="value-prop-grid">
      {t.valueProp.items.map((item) => (
        <IconCard
          icon={item.icon}
          title={item.title}
          description={item.description}
          backLabel={item.backLabel}
          backDescription={item.backDescription}
        />
      ))}
    </div>
  </div>
</section>
