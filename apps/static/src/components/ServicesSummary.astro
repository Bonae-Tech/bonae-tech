---
import type { Translations } from '@bonae/content';
import { serviceCardIconMarkup } from '../lib/icons';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const baseHref = t.lang === 'en' ? '/en/' : '/';
---

<section id="servicios" class="py-20 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-white text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.servicesSummary.sectionBadge}
      </span>
      <h2 class="section-title">{t.servicesSummary.title}</h2>
      <p class="section-subtitle">{t.servicesSummary.subtitle}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.servicesSummary.items.map((item) => (
        <a href={`${baseHref}#servicios-completos`} class="card group block text-left no-underline">
          <div class="w-12 h-12 rounded-xl bg-cream text-dark-blue flex items-center justify-center mb-5 group-hover:bg-dark-blue group-hover:text-white transition-all duration-300">
            <Fragment set:html={serviceCardIconMarkup[item.icon]} />
          </div>
          <h3 class="text-lg font-bold text-pacificblue mb-2 group-hover:text-dark-blue">{item.title}</h3>
          <p class="text-pacificblue text-sm leading-relaxed">{item.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
