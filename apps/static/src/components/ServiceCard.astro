---
import { serviceCardIconMarkup } from '../lib/icons';

interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
const iconSvg = serviceCardIconMarkup[icon] ?? serviceCardIconMarkup.web;
---

<article class="card group">
  <div class="w-12 h-12 rounded-xl bg-cream text-dark-blue flex items-center justify-center mb-4 group-hover:bg-dark-blue group-hover:text-white transition-all duration-300">
    <Fragment set:html={iconSvg} />
  </div>
  <h4 class="font-bold text-pacificblue mb-2 group-hover:text-dark-blue transition-colors">{title}</h4>
  <p class="text-pacificblue text-sm leading-relaxed">{description}</p>
</article>
