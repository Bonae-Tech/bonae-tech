{
  "name": "bonae-static",
  "version": "1.0.0",
  "description": "BONAE TECH marketing site (Astro)",
  "scripts": {
    "content:validate": "npm run validate:published -w @bonae/content",
    "predev": "npm run content:validate",
    "dev": "astro dev",
    "prebuild": "npm run content:validate",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "node ./scripts/inject-sw-build-hash.mjs && wrangler pages deploy dist --project-name bonae-tech"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "wrangler": "^3.99.0"
  },
  "dependencies": {
    "@bonae/content": "*",
    "@astrojs/tailwind": "^6.0.2",
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^4.16.19",
    "tailwindcss": "^3.4.19"
  }
}
