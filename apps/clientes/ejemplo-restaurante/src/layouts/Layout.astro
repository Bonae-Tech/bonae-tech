---
import '../styles/global.css';
import type { SiteContent, SiteSettings } from '../lib/content';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  content: SiteContent;
  settings: SiteSettings;
  whatsappHref: string;
}

const { content, settings, whatsappHref } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={content.metaDescription} />
    <meta name="theme-color" content="#5C3317" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${content.siteName} — ${content.siteTagline}`} />
    <meta property="og:description" content={content.metaDescription} />
    <meta property="og:locale" content="es_VE" />

    <title>{content.siteName} — {content.siteTagline}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
    <WhatsAppFloat href={whatsappHref} />
    <CookieBanner content={content} settings={settings} />
  </body>
</html>
