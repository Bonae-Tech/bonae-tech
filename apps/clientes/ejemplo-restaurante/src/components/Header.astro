---
import type { SiteContent } from '../lib/content';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-brand-cream shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group" aria-label={content.siteName}>
      <div class="w-9 h-9 rounded-lg bg-brand-dark flex items-center justify-center shadow-sm group-hover:bg-brand-dark-dark transition-colors">
        <span class="text-brand-accent font-bold text-lg leading-none">C</span>
      </div>
      <span class="font-bold text-brand-dark text-xl tracking-tight">{content.siteName}</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <a href="/" class="text-sm font-medium text-brand-muted hover:text-brand-dark transition-colors">{content.nav.home}</a>
      <a href="#menu" class="text-sm font-medium text-brand-muted hover:text-brand-dark transition-colors">{content.nav.menu}</a>
      <a href="#horarios" class="text-sm font-medium text-brand-muted hover:text-brand-dark transition-colors">{content.nav.hours}</a>
      <a href="#contacto" class="text-sm font-medium text-brand-muted hover:text-brand-dark transition-colors">{content.nav.contact}</a>
      <a href="#contacto" class="btn-primary text-sm py-2 px-4">{content.nav.cta}</a>
    </div>

    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-1" aria-label="Menú">
      <svg class="w-6 h-6 text-brand-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </nav>

  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block md:hidden border-t border-brand-cream bg-white px-4 py-4 space-y-3">
    <a href="/" class="block text-sm font-medium text-brand-muted hover:text-brand-dark py-1">{content.nav.home}</a>
    <a href="#menu" class="block text-sm font-medium text-brand-muted hover:text-brand-dark py-1">{content.nav.menu}</a>
    <a href="#horarios" class="block text-sm font-medium text-brand-muted hover:text-brand-dark py-1">{content.nav.hours}</a>
    <a href="#contacto" class="block text-sm font-medium text-brand-muted hover:text-brand-dark py-1">{content.nav.contact}</a>
    <a href="#contacto" class="block btn-primary text-center py-2 mt-2">{content.nav.cta}</a>
  </div>
</header>
