---
import type { SiteContent } from '../lib/content';

interface Props {
  content: SiteContent;
  whatsappHref: string;
}

const { content, whatsappHref } = Astro.props;
const { contact } = content;
---

<section id="contacto" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="section-title">{contact.title}</h2>
      <p class="section-subtitle mb-8">{contact.text}</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          WhatsApp
        </a>
        <a href={`mailto:${contact.email}`} class="btn-primary">
          {contact.email}
        </a>
      </div>
    </div>
  </div>
</section>
