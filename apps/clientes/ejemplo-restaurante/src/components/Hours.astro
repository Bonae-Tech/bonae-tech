---
import type { SiteContent } from '../lib/content';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { hours } = content;
---

<section id="horarios" class="py-16 md:py-24 bg-brand-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="section-title">{hours.title}</h2>

      <div class="card mt-8 text-left space-y-6">
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-lg bg-brand-dark/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-brand-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-brand-dark mb-1">Horario</h3>
            <p class="text-brand-muted">{hours.schedule}</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-lg bg-brand-dark/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-brand-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-brand-dark mb-1">Dirección</h3>
            <p class="text-brand-muted">{hours.address}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
