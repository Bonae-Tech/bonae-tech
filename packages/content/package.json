{
  "name": "@bonae/content",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    },
    "./content-store": {
      "types": "./dist/content-store.d.ts",
      "import": "./dist/content-store.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "validate": "node dist/cli.js",
    "validate:published": "node dist/cli.js ../../apps/static/content"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "license": "Apache-2.0"
}
